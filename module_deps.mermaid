graph TD
    RC["rag_core.py\nembeddings · vector store\nGemini API · query expansion\ncontext builder"]

    EN["pipeline_en.py\nEnglish prompt\nk=4 chunks"]
    HI["pipeline_hi.py\nHindi prompt\nk=5 chunks\ntransliteration"]
    ING["ingest.py\nload chunks\nsmart upsert"]
    DBG["search_debug.py\nraw retrieval\nno LLM"]
    EVL["eval.py\nkeyword hit rate\nsection hit rate"]

    API["api.py\nFastAPI server\nPOST /api/search\nGET /health"]

    RC --> EN
    RC --> HI
    RC --> ING
    RC --> DBG
    RC --> EVL

    EN --> API
    HI --> API

    EXP["expansion_rules.json\n(runtime config)"]
    EXP -.->|"loaded at startup"| RC

