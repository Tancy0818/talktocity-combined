import { getToken } from './auth'

const TIMEOUT_MS = 120_000

export class AuthError extends Error {
  constructor(msg) { super(msg); this.name = 'AuthError' }
}

export async function searchCity({ question, city, lang = 'en' }) {
  const token = getToken()
  if (!token) throw new AuthError('Not logged in. Please sign in with Google to search.')

  const controller = new AbortController()
  const timer = setTimeout(() => controller.abort(), TIMEOUT_MS)

  try {
    const res = await fetch('/api/search', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Authorization': `Bearer ${token}`,
      },
      body: JSON.stringify({ question, city: city || null, lang }),
      signal: controller.signal,
    })
    clearTimeout(timer)
    if (res.status === 401) throw new AuthError('Session expired. Please sign in again.')
    if (!res.ok) throw new Error(`Backend error ${res.status}: ${await res.text()}`)
    return res.json()
  } catch (err) {
    clearTimeout(timer)
    if (err.name === 'AbortError') throw new Error('Request timed out. Try a shorter question.')
    throw err
  }
}
